  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "FERC",
    "Form 1",
    "XBRL",
    "iXBRL",
    "utility",
    "electric",
    "parser",
    "R",
    "tidyverse"
  ],
  "author": "Jordi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JGARZO1/ferc-form1-parser.git"
  }
